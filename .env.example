# Base de Datos
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mail_manager?schema=public"
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mail_manager

# Servidor
PORT=3000
NODE_ENV=development

# Google OAuth2 (Gmail)
GOOGLE_CLIENT_ID=tu_client_id
GOOGLE_CLIENT_SECRET=tu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Microsoft OAuth2 (Outlook/Hotmail)
AZURE_CLIENT_ID=tu_client_id
AZURE_CLIENT_SECRET=tu_client_secret
AZURE_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback
AZURE_TENANT_ID=common

# JWT (Para el portal de usuario)
JWT_SECRET=tu_secreto_super_seguro
